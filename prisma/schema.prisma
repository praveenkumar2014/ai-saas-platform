// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USER & AUTHENTICATION
// ============================================

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  role          Role      @default(USER)
  
  // OAuth providers
  accounts      Account[]
  sessions      Session[]
  
  // User data
  profile       UserProfile?
  subscriptions Subscription[]
  payments      Payment[]
  workflows     Workflow[]
  tasks         Task[]
  
  // Content
  contentItems  ContentItem[]
  chatMessages  ChatMessage[]
  
  // AI
  aiAgents      AIAgent[]
  aiPrompts     AIPrompt[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  phone       String?
  address     String?
  city        String?
  country     String?
  bio         String?  @db.Text
  preferences Json?    @default("{}")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// RBAC - ROLES & PERMISSIONS
// ============================================

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  resource    String   // e.g., "content", "users", "workflows"
  action      String   // e.g., "create", "read", "update", "delete"
  
  roles       RolePermission[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([resource, action])
}

model RolePermission {
  id          String   @id @default(cuid())
  role        Role
  permissionId String
  permission  Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([role, permissionId])
}

// ============================================
// SUBSCRIPTIONS & PAYMENTS
// ============================================

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

enum PlanType {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  planType    PlanType
  status      SubscriptionStatus @default(PENDING)
  
  startDate   DateTime
  endDate     DateTime?
  
  stripeCustomerId String?
  stripeSubscriptionId String?
  
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  UPI
  CARD
  BANK_TRANSFER
}

model Payment {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("INR")
  
  status        PaymentStatus @default(PENDING)
  method        PaymentMethod
  
  transactionId String?       @unique
  upiId         String?
  
  description   String?
  metadata      Json?         @default("{}")
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  @@index([userId])
  @@index([status])
}

// ============================================
// WORKFLOW & TASK MANAGEMENT
// ============================================

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model Workflow {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  description String?  @db.Text
  
  trigger     Json?    @default("{}")  // Trigger configuration
  config      Json     @default("{}")  // Workflow configuration
  
  isActive    Boolean  @default(true)
  
  tasks       Task[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([isActive])
}

model Task {
  id          String    @id @default(cuid())
  workflowId  String?
  workflow    Workflow? @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  description String?   @db.Text
  
  status      TaskStatus @default(PENDING)
  result      Json?     @default("{}")
  error       String?   @db.Text
  
  startedAt   DateTime?
  completedAt DateTime?
  
  logs        TaskLog[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([workflowId])
  @@index([userId])
  @@index([status])
}

model TaskLog {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  level     String   // INFO, WARN, ERROR
  message   String   @db.Text
  metadata  Json?    @default("{}")
  
  createdAt DateTime @default(now())
  
  @@index([taskId])
}

// ============================================
// CONTENT MANAGEMENT (HEADLESS CMS)
// ============================================

enum ContentType {
  PAGE
  POST
  PRODUCT
  CATEGORY
  CUSTOM
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model ContentModel {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  
  schema      Json     @default("{}")  // Dynamic schema definition
  
  contentItems ContentItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContentItem {
  id          String        @id @default(cuid())
  modelId     String?
  model       ContentModel? @relation(fields: [modelId], references: [id])
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title       String
  slug        String        @unique
  type        ContentType   @default(CUSTOM)
  status      ContentStatus @default(DRAFT)
  
  content     Json          @default("{}")  // Dynamic content based on model schema
  metadata    Json          @default("{}")  // SEO metadata, etc.
  
  publishedAt DateTime?
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@index([modelId])
  @@index([userId])
  @@index([slug])
  @@index([status])
}

// ============================================
// AI SYSTEM
// ============================================

enum AIProvider {
  OPENAI
  ANTHROPIC
  OLLAMA
  LOCAL
}

enum AIAgentType {
  CODE
  CONTENT
  MARKETING
  AUTOMATION
  CUSTOM
}

model AIAgent {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  type        AIAgentType
  description String?    @db.Text
  
  provider    AIProvider @default(OPENAI)
  model       String     // e.g., "gpt-4", "claude-3"
  
  config      Json       @default("{}")  // Agent configuration
  systemPrompt String?   @db.Text
  
  isActive    Boolean    @default(true)
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@index([userId])
  @@index([type])
}

model AIPrompt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  description String?  @db.Text
  template    String   @db.Text
  
  variables   Json?    @default("{}")  // Prompt variables
  
  category    String?  // e.g., "code", "content", "marketing"
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([category])
}

model ChatMessage {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role        String   // "user", "assistant", "system"
  content     String   @db.Text
  
  model       String?  // AI model used
  tokens      Int?     // Token count
  
  metadata    Json?    @default("{}")
  
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// SOCIAL MEDIA & SEO
// ============================================

enum SocialPlatform {
  TWITTER
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  YOUTUBE
  TIKTOK
}

model SocialPost {
  id          String         @id @default(cuid())
  userId      String
  platform    SocialPlatform
  
  content     String         @db.Text
  mediaUrls   String[]       @default([])
  
  status      TaskStatus     @default(PENDING)
  scheduledAt DateTime?
  publishedAt DateTime?
  
  postId      String?        // Platform post ID
  metrics     Json?          @default("{}")  // Likes, shares, etc.
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  @@index([userId])
  @@index([platform])
  @@index([status])
}

model SEOReport {
  id          String   @id @default(cuid())
  contentId   String?  // Link to content if applicable
  
  keywords    String[]
  suggestions String[] @db.Text
  
  score       Int
  metadata    Json?    @default("{}")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// ANALYTICS
// ============================================

model AnalyticsEvent {
  id          String   @id @default(cuid())
  userId      String?
  
  eventType   String
  properties  Json     @default("{}")
  
  sessionId   String?
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}
